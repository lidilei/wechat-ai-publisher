# ===========================================
# 微信公众号 AI 发布工具 - 配置模板
# ===========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的真实 API Key
# 3. 不要将 .env 文件提交到 Git！
# ===========================================

# -------------------------------------------
# 微信公众号配置
# 获取方式：https://mp.weixin.qq.com
# 路径：设置与开发 → 基本配置
# -------------------------------------------
WECHAT_APPID=你的 AppID（如：wx256ca394522fb41c）
WECHAT_SECRET=你的 AppSecret（如：af7542ca9f2c4e7780b6dc275205e3ed）
WECHAT_AUTHOR=你的作者名（如：地雷 Ravi）

# -------------------------------------------
# 豆包 AI 配置
# 获取方式：https://console.volcengine.com/ark
# -------------------------------------------
# API Key：访问 apiKey 管理页面创建
DOUBAO_API_KEY=你的豆包 API Key

# 端点 ID：访问端点管理，找到图像生成端点
# 格式：ep-xxxxxxxxxxxx
DOUBAO_ENDPOINT=你的端点 ID（如：ep-20260109204533-mrl4r）

# -------------------------------------------
# 可选配置
# -------------------------------------------
# 文章主题：AI 工具 / 大模型 / AI Agent / 行业动态
ARTICLE_TOPIC=AI 工具

# CSS 风格：purple / orangeheart / github
ARTICLE_STYLE=github

# 配图数量：仅封面 / 封面 +2 张 / 封面 +3 张
ARTICLE_IMAGES=封面 +3 张

# -------------------------------------------
# 提示
# -------------------------------------------
# 1. 配置完成后，运行：node scripts/publish-with-ai-images-fixed.js
# 2. 详细文档：docs/setup-guide.md
# 3. 遇到问题？查看：docs/setup-guide.md#常见问题
